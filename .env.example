# Anthropic API key (required for Claude calls). Without it, the doctor
# runs in classify-only mode (scans + classifies but proposes no fixes).
ANTHROPIC_API_KEY=sk-ant-...

# Daily spend cap in USD. Default 0.50.
LOG_DOCTOR_DAILY_BUDGET_USD=0.50

# Auto-apply SAFE-classified fixes without asking. Default true.
LOG_DOCTOR_AUTO_APPLY_SAFE=true

# Scan cadence in minutes when running `claude-log-doctor watch`. Default 15.
LOG_DOCTOR_INTERVAL_MIN=15

# Master switch. Set to "false" to disable without uninstalling. Default true.
LOG_DOCTOR_ENABLED=true

# Anthropic model. Default claude-opus-4-7 (best fix quality, higher cost).
# For lower cost, use claude-sonnet-4-6 or claude-haiku-4-5-20251001.
LOG_DOCTOR_MODEL=claude-opus-4-7

# --- Optional: Telegram notifications for NEEDS_APPROVAL fixes ---
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# --- Optional: Slack notifications ---
SLACK_WEBHOOK_URL=
